{
  "name": "nodexbt-ui",
  "version": "0.1.0",
  "description": "Shared styling primitives — theme tokens, Tailwind v4 preset, cn() utility, and ThemeProvider",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./globals.css": "./src/globals.css",
    "./postcss": {
      "types": "./dist/postcss.d.ts",
      "import": "./dist/postcss.js"
    }
  },
  "files": [
    "dist",
    "src/globals.css"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "react": "^19.2.4",
    "typescript": "^5"
  },
  "license": "MIT"
}
